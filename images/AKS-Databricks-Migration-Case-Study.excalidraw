      "isDeleted": false,
      "boundElements": [],
      "updated": 1776010180002,
      "link": null,
      "locked": false,
      "text": "\nDeliver \n- Governance via Azure Policy\n[OPA / Spacelift et all]\n- IAC to maintain azure workloads\non application plane, control plane\n- Deploy services like key vault,\nstorage container [state file management],\nazure configuration manager\n- Create flavours of runners for IAC, \nDeployment of services, keys & secrets,\napplications & certificates",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\nDeliver \n- Governance via Azure Policy\n[OPA / Spacelift et all]\n- IAC to maintain azure workloads\non application plane, control plane\n- Deploy services like key vault,\nstorage container [state file management],\nazure configuration manager\n- Create flavours of runners for IAC, \nDeployment of services, keys & secrets,\napplications & certificates",
      "autoResize": true,
      "lineHeight": 1.25
