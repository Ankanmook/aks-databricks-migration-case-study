      "boundElements": null,
      "updated": 1776029290522,
      "link": null,
      "locked": false,
      "text": "WAVE 3 - Existing Container Instaces\n& Mixed compute workloads\n- apps already partly containerized\n- workload on ad hoc container platforms\n\nSteps\n- compare runtime assumptions\n- move to std base image\n- move deployment spec to Kustomize\n- deploy into std namespace & ingress model",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "WAVE 3 - Existing Container Instaces\n& Mixed compute workloads\n- apps already partly containerized\n- workload on ad hoc container platforms\n\nSteps\n- compare runtime assumptions\n- move to std base image\n- move deployment spec to Kustomize\n- deploy into std namespace & ingress model",
      "autoResize": true,
      "lineHeight": 1.25
    },
