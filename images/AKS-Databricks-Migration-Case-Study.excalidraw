    {
      "id": "RQ7lAqzrDbMxjl5Pas4WI",
      "type": "text",
      "x": 3270.9229279584533,
      "y": 1328.5752319043495,
      "width": 818.3877563476562,
      "height": 1575,
      "angle": 0,
